      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst rawOutput = input.output || input.text || JSON.stringify(input);\n\nlet parsed;\ntry {\n  // Extract JSON from the AI response string\n  const match = rawOutput.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(match[0]);\n} catch(e) {\n  parsed = { deal: false, reason: \"Ошибка парсинга\" };\n}\n\nreturn [{\n  json: {\n    title: input.title,\n    price: input.price,\n    link: input.link,\n    deal: parsed.deal,\n    reason: parsed.reason\n  }\n}];"
      },
