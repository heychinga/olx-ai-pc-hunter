      "parameters": {
        "jsCode": "const titles = $input.first().json.title;\nconst prices = $input.first().json.price;\nconst links = $input.first().json.link.filter((_, index) => index % 2 === 0);\n\n// Просто готовим список из 52 позиций\nreturn titles.slice(1, 9).map((title, i) => ({\n  json: {\n    title: title,\n    price: prices[i],\n    link: links[i] ? 'https://www.olx.kz' + links[i] : null\n  }\n}));\n\n"
      },
