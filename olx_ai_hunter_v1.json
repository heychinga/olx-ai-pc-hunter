    {
      "parameters": {
        "jsCode": "// 1. Берем HTML из предыдущего узла (Get_details)\nconst html = $input.first().json.data || \"\"; \n\n// 2. Ищем описание через регулярку\nconst regex = /\"description\":\"(.*?)\"/;\nconst match = html.match(regex);\n\nlet description = \"Описание не найдено\";\nif (match && match[1]) {\n    description = match[1]\n        .replace(/\\\\n/g, ' ')\n        .replace(/\\\\r/g, '')\n        .replace(/\\\\\"/g, '\"');\n}\n\n// 3. Собираем объект. \n// ВАЖНО: Проверьте имя узла в кавычках ниже! \n// Если ваш узел называется \"Loop Over Items1\", добавьте единицу.\nconst itemData = $node[\"Loop Over Items1\"].json; \n\nreturn {\n  title: itemData.title,\n  price: itemData.price,\n  link: itemData.link,\n  description: description\n};"
      },
